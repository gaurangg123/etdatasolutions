# ── Contact Form (SMTP) ─────────────────────────────────────────
# Required for the /api/contact route to send emails.
# Use Gmail App Password or any SMTP provider (Resend, SendGrid, etc.)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Email address that receives contact form submissions
CONTACT_TO=bobby@etdatasolutions.com

# ── Optional ────────────────────────────────────────────────────
# Max contact form submissions per IP per hour (default: 5)
RATE_LIMIT_MAX=5

# Node environment
NODE_ENV=development
