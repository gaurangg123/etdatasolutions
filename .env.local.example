# Resend — required for contact form delivery
RESEND_API_KEY=

# Override sender (must be a verified Resend domain/sender)
# CONTACT_FROM_EMAIL=ET Data Solutions <noreply@etdatasolutions.com>

# Override recipients (comma-separated). Defaults to bobby@ + gaurang@
# CONTACT_TO_EMAILS=bobby@etdatasolutions.com,gaurang@etdatasolutions.com

# Calendly — public-facing 30-min booking URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/bobby-etdatasolutions/30min
