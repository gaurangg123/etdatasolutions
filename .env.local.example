# ── ET Data Solutions — Environment Variables ──────────────────────────────
#
# STEP 1: Rename this file to .env.local
# STEP 2: Fill in your IONOS email password below
# STEP 3: Run: npm install nodemailer @types/nodemailer
# STEP 4: Restart the dev server: npm run dev
#
# ── IONOS SMTP (your existing IONOS email) ─────────────────────────────────
#
# These settings work for ALL IONOS email accounts automatically.
# Just fill in your email address and webmail password.
#
SMTP_USER=bobby@etdatasolutions.com
SMTP_PASS=your_ionos_webmail_password_here
#
# IONOS SMTP config (already hardcoded in route.ts — no need to change):
#   Host: smtp.ionos.com
#   Port: 587 (STARTTLS)
#
# ── Where to find your IONOS password ─────────────────────────────────────
# Log in to: https://www.ionos.com
# Go to: Email → Manage Email Accounts → your email → Settings
# The password is the same one you use for webmail.ionos.com
# ──────────────────────────────────────────────────────────────────────────
